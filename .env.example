# ── Yewogen Derash environment variables ─────────────────────────
# Copy to .env.local and fill in real values. NEVER commit .env.local.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Supabase Postgres — SHARED free-tier project).
# IMPORTANT: this app lives in its own Postgres schema `yewogen`, fully
# separated from other projects' tables in `public`. The `schema=yewogen`
# parameter below is REQUIRED — never remove it, or Prisma would look at
# the shared `public` schema instead.
# Get both URLs from Supabase Dashboard → Connect → Connection string:
#   DATABASE_URL  = Transaction pooler (port 6543)
#   DIRECT_URL    = Session pooler / direct (port 5432)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&schema=yewogen
DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?schema=yewogen

# Supabase (Storage for KYC documents + campaign media).
# Shared project ⇒ buckets are prefixed: `yewogen-kyc` (private),
# `yewogen-media` (public). Never write to other projects' buckets.
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Auth.js
AUTH_SECRET=generate_with_npx_auth_secret
AUTH_TRUST_HOST=true

# Chapa payment gateway
CHAPA_SECRET_KEY=CHASECK_TEST-your_key
CHAPA_WEBHOOK_SECRET=your_webhook_secret

# CallMeBot WhatsApp alerts (per-owner API keys are stored in the DB;
# this is the platform fallback/admin alert number)
ADMIN_WHATSAPP_PHONE=
ADMIN_CALLMEBOT_APIKEY=
