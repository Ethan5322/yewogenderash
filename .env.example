# ── Yewogen Derash environment variables ─────────────────────────
# Copy to .env.local and fill in real values. NEVER commit .env.local.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Supabase Postgres — SHARED free-tier project).
# IMPORTANT: this DB is shared with the user's other apps. Every table is
# yd_-prefixed and lives in the default `public` schema. Do NOT add a
# `schema=` param, and never touch tables that don't start with `yd_`.
# Get both URLs from Supabase Dashboard → Connect → Connection string:
#   DATABASE_URL  = Transaction pooler (port 6543)
#   DIRECT_URL    = Session pooler / direct (port 5432)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Supabase (Storage for KYC documents + campaign media).
# Shared project ⇒ buckets are yd-prefixed: `yd-kyc` (private),
# `yd-media` (public). Never write to other projects' buckets.
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Auth.js
AUTH_SECRET=generate_with_npx_auth_secret
AUTH_TRUST_HOST=true

# Chapa payment gateway (Dashboard → Settings → API for the keys;
# Settings → Webhooks for the Secret Hash used to verify webhook signatures)
CHAPA_SECRET_KEY=CHASECK_TEST-your_secret_key
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-your_public_key
CHAPA_ENCRYPTION_KEY=your_encryption_key
CHAPA_WEBHOOK_SECRET=your_webhook_secret_hash

# CallMeBot WhatsApp alerts (per-owner API keys are stored in the DB;
# this is the platform fallback/admin alert number)
ADMIN_WHATSAPP_PHONE=
ADMIN_CALLMEBOT_APIKEY=

# Face recognition (optional). When FACE_SERVICE_URL is set, the InsightFace
# microservice in face-service/ is used as the AUTHORITATIVE KYC same-person
# check (live selfie vs ID photo). If unset, the app falls back to the
# in-browser @vladmandic/face-api engine. Deploy face-service/ on Hugging Face
# Spaces (Docker) — see face-service/README.md.
FACE_SERVICE_URL=
FACE_API_KEY=
