// Yewogen Derash — data model.
//
// SHARED SUPABASE PROJECT: this database is shared with the user's other
// apps. EVERY table/enum here maps to a yd_-prefixed Postgres name via
// @@map (yd_users, yd_role, ...). Never create unprefixed objects, and
// never touch tables that don't start with yd_ — they belong to other
// projects. Storage buckets follow the same rule: yd-kyc, yd-media.
//
// Core invariants encoded here:
//   * One campaign = one querycode (unique) = one ledger (donations relation).
//   * Donations belong to exactly one campaign (required FK).
//   * Payouts are per-campaign, admin-approved, and reference the approving admin.
//   * Money is Decimal(12,2) — never floats.
//   * Every webhook event is stored (idempotency + audit).

generator client {
  provider = "prisma-client-js"
}

// Prisma 7: connection URLs live in prisma.config.ts (CLI) and the
// driver adapter in lib/db.ts (runtime) — never here.
datasource db {
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────────────────────

enum Role {
  DONOR
  OWNER
  ADMIN

  @@map("yd_role")
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
  RESUBMIT

  @@map("yd_verification_status")
}

enum BiometricStatus {
  NOT_CAPTURED
  PENDING
  VERIFIED
  REJECTED
  RESUBMIT

  @@map("yd_biometric_status")
}

enum CampaignStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  SUSPENDED
  COMPLETED
  ARCHIVED
  REJECTED

  @@map("yd_campaign_status")
}

enum CampaignCategory {
  MEDICAL
  EDUCATION
  COMMUNITY
  BUSINESS
  EMERGENCY
  OTHER

  @@map("yd_campaign_category")
}

enum DonationStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  REFUNDED
  DISPUTED

  @@map("yd_donation_status")
}

enum PayoutStatus {
  REQUESTED
  APPROVED
  PAID
  REJECTED
  CANCELLED

  @@map("yd_payout_status")
}

enum DocumentType {
  NATIONAL_ID
  PASSPORT
  SELFIE
  PROOF_OF_ADDRESS
  MEDICAL_LETTER
  EDUCATION_LETTER
  COMMUNITY_LETTER
  BUSINESS_REGISTRATION
  OTHER_SUPPORTING

  @@map("yd_document_type")
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
  RESUBMIT

  @@map("yd_document_status")
}

enum NotificationChannel {
  WHATSAPP
  EMAIL
  SMS

  @@map("yd_notification_channel")
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED

  @@map("yd_notification_status")
}

enum OtpPurpose {
  EMAIL_VERIFY
  PHONE_VERIFY
  PASSWORD_RESET
  LOGIN_2FA

  @@map("yd_otp_purpose")
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@map("yd_blog_status")
}

// ── Identity ─────────────────────────────────────────────────────

model User {
  id                 String             @id @default(cuid())
  name               String
  email              String             @unique
  emailVerifiedAt    DateTime?
  phone              String?            @unique
  phoneVerifiedAt    DateTime?
  passwordHash       String
  role               Role               @default(DONOR)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  isBanned           Boolean            @default(false)
  // Delegated administration. A super admin ("main admin") implicitly holds
  // every permission and can manage other admins; sub-admins (role ADMIN,
  // isSuperAdmin false) hold only the capabilities toggled on in
  // adminPermissions, e.g. { "kyc": true, "payouts": false }.
  isSuperAdmin       Boolean            @default(false)
  adminPermissions   Json               @default("{}")
  /// Staff identifier for admins/sub-admins, e.g. YWD-ADM-7KQ2. Issued when an
  /// admin account is created; null for non-admin users.
  adminCode          String?            @unique
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  ownerProfile CampaignOwner?
  donations    Donation[]
  otpCodes     OtpCode[]
  auditLogs    AuditLog[]     @relation("AuditActor")
  blogPosts    BlogPost[]

  @@map("yd_users")
}

model OtpCode {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose   OtpPurpose
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())

  @@index([userId, purpose])
  @@map("yd_otp_codes")
}

// ── Campaign owners (KYC) ────────────────────────────────────────

model CampaignOwner {
  id                 String          @id @default(cuid())
  userId             String          @unique
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  idNumber           String?
  biometricStatus    BiometricStatus @default(NOT_CAPTURED)
  /// 128-D face descriptor from the live biometric capture (the enrolment
  /// template). Compared against the ID photo at registration and against the
  /// live face at login. Stored as a JSON number array.
  faceDescriptor     Json?
  /// 128-D descriptor detected in the uploaded ID-card photo.
  idPhotoDescriptor  Json?
  /// Raw match score. Meaning depends on faceEngine: face-api = Euclidean
  /// distance (lower better), insightface = cosine similarity (higher better).
  faceMatchScore     Float?
  /// Engine-agnostic verdict: did the live face match the ID photo?
  faceMatched        Boolean?
  /// Which engine produced the verdict: "insightface" or "face-api".
  faceEngine         String?
  /// Public verification code shown on the author profile (e.g. YWD-A1B2C3)
  authorCode         String?         @unique
  /// Platform trust seal — set only by admin approval, never user-editable
  mulesooVerified    Boolean         @default(false)
  verifiedAt         DateTime?
  /// Anti-fraud: an admin has flagged this owner as suspicious (brief §13).
  flagged            Boolean         @default(false)
  flagReason         String?
  /// Payout account details (bank/telebirr), JSON kept admin-readable only
  payoutAccount      Json?
  /// Public ID-card portrait (gallery upload, auto-cropped square) in yd-media.
  /// Distinct from the private KYC selfie — this is the photo shown ON the
  /// corporate Fundraiser ID card.
  idPhotoUrl         String?
  /// Owner preference: WhatsApp alert on each successful donation
  whatsappAlerts     Boolean         @default(true)
  whatsappPhone      String?
  callmebotApiKey    String?
  termsAcceptedAt    DateTime?
  feesAcceptedAt     DateTime?
  biometricConsentAt DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  campaigns      Campaign[]
  documents      VerificationDocument[]
  payouts        Payout[]
  notifications  Notification[]
  payoutAccounts PayoutAccount[]
  messages       Message[]

  @@map("yd_campaign_owners")
}

model VerificationDocument {
  id           String         @id @default(cuid())
  ownerId      String
  owner        CampaignOwner  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  documentType DocumentType
  /// Path in the private Supabase Storage bucket — never a public URL
  fileUrl      String
  status       DocumentStatus @default(PENDING)
  adminNote    String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([ownerId, status])
  @@map("yd_verification_documents")
}

// ── Campaigns ────────────────────────────────────────────────────

model Campaign {
  id            String           @id @default(cuid())
  ownerId       String
  owner         CampaignOwner    @relation(fields: [ownerId], references: [id])
  title         String
  slug          String           @unique
  description   String
  story         String?
  category      CampaignCategory
  targetAmount  Decimal          @db.Decimal(12, 2)
  /// Denormalised sum of SUCCESS donations — updated only inside the same
  /// transaction that marks a donation SUCCESS/REFUNDED.
  currentAmount Decimal          @default(0) @db.Decimal(12, 2)
  currency      String           @default("ETB")
  status        CampaignStatus   @default(DRAFT)
  /// One campaign, one querycode. QR encodes /q/[queryCode].
  queryCode     String           @unique
  qrCodeUrl     String?
  heroImageUrl  String?
  location      String?
  endDate       DateTime?
  isFeatured    Boolean          @default(false)
  /// Anti-fraud: an admin has flagged this campaign as suspicious (brief §13).
  flagged       Boolean          @default(false)
  flagReason    String?
  reviewedAt    DateTime?
  reviewNote    String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  donations     Donation[]
  payouts       Payout[]
  updates       CampaignUpdate[]
  notifications Notification[]
  feeLedgers    FeeLedger[]
  balance       CampaignBalance?
  documents     CampaignDocument[]

  @@index([status, category])
  @@index([ownerId])
  @@map("yd_campaigns")
}

model CampaignUpdate {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  title      String
  body       String
  createdAt  DateTime @default(now())

  @@index([campaignId])
  @@map("yd_campaign_updates")
}

/// Per-campaign proof document (brief §6.1/§6.2): the category-matched evidence
/// a fundraiser must attach to EACH campaign at creation — a hospital letter for
/// a medical campaign, a school letter for education, etc. Stored privately in
/// yd-kyc; only admins view it (signed URLs), and they check it before approval.
model CampaignDocument {
  id           String         @id @default(cuid())
  campaignId   String
  campaign     Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  documentType DocumentType
  /// Path in the private Supabase Storage bucket — never a public URL.
  fileUrl      String
  status       DocumentStatus @default(PENDING)
  adminNote    String?
  createdAt    DateTime       @default(now())

  @@index([campaignId])
  @@map("yd_campaign_documents")
}

// ── Money ────────────────────────────────────────────────────────

model Donation {
  id                   String         @id @default(cuid())
  campaignId           String
  campaign             Campaign       @relation(fields: [campaignId], references: [id])
  /// Optional — anonymous donations are allowed
  donorId              String?
  donor                User?          @relation(fields: [donorId], references: [id])
  donorName            String?
  /// Gross amount the donor paid (what Chapa charged).
  amount               Decimal        @db.Decimal(12, 2)
  /// Platform fee taken via Chapa split at transaction time (3% of gross).
  platformFee          Decimal        @default(0) @db.Decimal(12, 2)
  /// Net credited to the campaign = amount − platformFee.
  netAmount            Decimal        @default(0) @db.Decimal(12, 2)
  /// Fee rate applied, kept for audit even if the platform rate changes later.
  feeRate              Decimal        @default(0.03) @db.Decimal(5, 4)
  currency             String         @default("ETB")
  paymentMethod        String?
  /// Our transaction reference sent to Chapa (tx_ref) — unique for idempotency
  txRef                String         @unique
  gatewayTransactionId String?
  status               DonationStatus @default(PENDING)
  webhookPayload       Json?
  paidAt               DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  feeLedger FeeLedger?

  @@index([campaignId, status])
  @@index([donorId])
  @@map("yd_donations")
}

model Payout {
  id                String        @id @default(cuid())
  campaignId        String
  campaign          Campaign      @relation(fields: [campaignId], references: [id])
  ownerId           String
  owner             CampaignOwner @relation(fields: [ownerId], references: [id])
  amount            Decimal       @db.Decimal(12, 2)
  currency          String        @default("ETB")
  status            PayoutStatus  @default(REQUESTED)
  payoutReference   String?
  approvedByAdminId String?
  approvedAt        DateTime?
  paidAt            DateTime?
  note              String?
  /// True when the automated approval rules cleared this request (no human
  /// reviewer). See lib/payouts.ts evaluateAutoApproval().
  autoApproved      Boolean       @default(false)
  /// Snapshot of which rule decided this request, for audit.
  reviewReason      String?
  /// The payout account (verified bank / Chapa subaccount) funds are sent to.
  payoutAccountId   String?
  payoutAccountRef  PayoutAccount? @relation(fields: [payoutAccountId], references: [id])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([campaignId])
  @@index([ownerId, status])
  @@map("yd_payouts")
}

/// Raw gateway webhook events — stored before processing for idempotency,
/// replay protection, and audit. Never delete.
model WebhookEvent {
  id          String    @id @default(cuid())
  provider    String    @default("chapa")
  /// Provider event id or tx_ref — unique so duplicates are ignored
  externalRef String    @unique
  payload     Json
  signatureOk Boolean
  processedAt DateTime?
  outcome     String?
  createdAt   DateTime  @default(now())

  @@map("yd_webhook_events")
}

// ── Notifications ────────────────────────────────────────────────

model Notification {
  id         String              @id @default(cuid())
  ownerId    String?
  owner      CampaignOwner?      @relation(fields: [ownerId], references: [id])
  campaignId String?
  campaign   Campaign?           @relation(fields: [campaignId], references: [id])
  channel    NotificationChannel
  message    String
  status     NotificationStatus  @default(QUEUED)
  error      String?
  sentAt     DateTime?
  createdAt  DateTime            @default(now())

  @@index([ownerId])
  @@index([campaignId])
  @@map("yd_notifications")
}

// ── Governance ───────────────────────────────────────────────────

/// Append-only log of every admin action (and security-relevant user events).
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id])
  action     String
  entityType String?
  entityId   String?
  detail     Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@map("yd_audit_logs")
}

/// Admin-managed site content (home copy, FAQ, fees, banners, contact...)
model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedBy String?
  updatedAt DateTime @updatedAt

  @@map("yd_site_content")
}

// ── Money ledger & balances ──────────────────────────────────────

/// One row per SUCCESS donation recording the exact fee split. Append-only
/// financial record — gross = donor paid, fee = platform's 3% cut (taken by
/// Chapa split at transaction time), net = credited to the campaign balance.
/// Never mutate a row; corrections are new compensating rows.
model FeeLedger {
  id                String   @id @default(cuid())
  donationId        String   @unique
  donation          Donation @relation(fields: [donationId], references: [id])
  campaignId        String
  campaign          Campaign @relation(fields: [campaignId], references: [id])
  grossAmount       Decimal  @db.Decimal(12, 2)
  feeAmount         Decimal  @db.Decimal(12, 2)
  netAmount         Decimal  @db.Decimal(12, 2)
  feeRate           Decimal  @db.Decimal(5, 4)
  currency          String   @default("ETB")
  /// Chapa subaccount the net portion was split to (fundraiser's bank).
  chapaSubaccountId String?
  createdAt         DateTime @default(now())

  @@index([campaignId])
  @@map("yd_fee_ledger")
}

/// Per-campaign money summary — the authoritative balance surface. Kept in
/// sync inside the same transaction that settles a donation or pays out.
/// Separate row per campaign: funds are NEVER pooled across campaigns.
model CampaignBalance {
  id              String   @id @default(cuid())
  campaignId      String   @unique
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  /// Sum of gross donor payments that reached SUCCESS.
  grossRaised     Decimal  @default(0) @db.Decimal(12, 2)
  /// Sum of platform fees taken on those donations.
  totalFees       Decimal  @default(0) @db.Decimal(12, 2)
  /// grossRaised − totalFees — the campaign's own money.
  netRaised       Decimal  @default(0) @db.Decimal(12, 2)
  /// Sum of payouts requested/approved/paid (reserved against net).
  totalWithdrawn  Decimal  @default(0) @db.Decimal(12, 2)
  /// netRaised − totalWithdrawn — what the owner can still request.
  availableAmount Decimal  @default(0) @db.Decimal(12, 2)
  currency        String   @default("ETB")
  updatedAt       DateTime @updatedAt

  @@map("yd_campaign_balances")
}

/// A fundraiser's verified payout destination. Promoted from the old
/// CampaignOwner.payoutAccount JSON to a first-class table so each account
/// maps to a Chapa subaccount and carries its own verification state.
model PayoutAccount {
  id                String        @id @default(cuid())
  ownerId           String
  owner             CampaignOwner @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  accountName       String
  bankName          String
  /// Chapa bank id (from the /banks endpoint) used to create the subaccount.
  bankCode          String
  accountNumber     String
  /// Chapa subaccount id — the split target for this owner's donations.
  chapaSubaccountId String?
  isVerified        Boolean       @default(false)
  verifiedAt        DateTime?
  /// The owner's currently active payout account (only one should be true).
  isDefault         Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  payouts Payout[]

  @@index([ownerId])
  @@map("yd_payout_accounts")
}

// ── Messaging (fundraiser ↔ admin) ───────────────────────────────

/// A message between a fundraiser and the admin team.
///  - Owner→admin and admin→owner replies both carry `ownerId` (the thread).
///  - An admin NOTICE to every fundraiser is `isBroadcast` with `ownerId` null.
/// `fromAdmin` gives direction; the read flags drive unread badges per side.
model Message {
  id           String         @id @default(cuid())
  ownerId      String?
  owner        CampaignOwner? @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  /// The user who wrote it (admin user or the owner's user). Kept for audit.
  senderUserId String?
  fromAdmin    Boolean        @default(false)
  isBroadcast  Boolean        @default(false)
  subject      String?
  body         String
  readByOwner  Boolean        @default(false)
  readByAdmin  Boolean        @default(false)
  createdAt    DateTime       @default(now())

  @@index([ownerId, createdAt])
  @@index([isBroadcast, createdAt])
  @@map("yd_messages")
}

// ── Blog / content marketing ─────────────────────────────────────

/// Public blog posts (trust content, success stories, guides). Authored by
/// admins; only PUBLISHED posts are visible on the public site.
model BlogPost {
  id            String     @id @default(cuid())
  slug          String     @unique
  title         String
  excerpt       String
  body          String
  coverImageUrl String?
  status        BlogStatus @default(DRAFT)
  authorId      String?
  author        User?      @relation(fields: [authorId], references: [id])
  publishedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([status, publishedAt])
  @@map("yd_blog_posts")
}
