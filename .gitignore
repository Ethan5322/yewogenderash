# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# playwright
/test-results/
/playwright-report/
/blob-report/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Personal notes (never commit — may contain secrets)
NEXT-STEPS.md

# Note: "Yewogen Derash QR Codes/" is intentionally tracked so the codes survive
# anywhere the repo is cloned. They encode NEXT_PUBLIC_APP_URL, so regenerate
# them with `node scripts/make-qr.mjs` whenever that URL changes.
